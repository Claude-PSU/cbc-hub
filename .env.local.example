# ---- Google Calendar ---- #
GOOGLE_CALENDAR_API_KEY=
GOOGLE_CALENDAR_ID=

# ---- GitHub (optional) ---- #
# Raises GitHub API rate limit from 60 to 5,000 requests/hr for the repos proxy
# GITHUB_TOKEN=

# --- Gmail ---- #
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ---- Firebase Account Key (Firebase Admin) --- #
# Make sure this is B64 Encoded
FIREBASE_SERVICE_ACCOUNT_KEY=